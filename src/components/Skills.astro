---
import { Icon } from 'astro-icon/components';

const skillGroups = [
  {
    title: "Expertise Frontend",
    icon: "lucide:layout-template",
    skills: ["TypeScript", "React", "Astro", "Tailwind CSS 4", "Next.js", "Optimisation SEO"]
  },
  {
    title: "Architecture Backend",
    icon: "lucide:server",
    skills: ["Node.js", "NestJS", "Express", "PostgreSQL", "MySQL", "TypeORM / Prisma", "API Design"]
  },
  {
    title: "Qualité & DevOps",
    icon: "lucide:shield-check",
    skills: ["Git", "Docker", "CI/CD", "Jest", "Linux", "Vercel", "Clean Code"]
  }
];
---

<section id="skills" class="section-container relative">
  <div class="flex flex-col gap-4 mb-16 max-w-xl">
    <h2 class="text-3xl md:text-4xl font-bold">Expertise technique</h2>
    <p class="text-zinc-400">
      Une approche fullstack centrée sur le typage strict et la robustesse des architectures.
    </p>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
    {skillGroups.map((group) => (
      <div 
        class="group relative overflow-hidden p-8 rounded-3xl border border-zinc-800 bg-zinc-900/20 hover:bg-zinc-900/40 hover:border-indigo-500/50 transition-all duration-500"
      >
        <div class="absolute -bottom-12 -right-12 w-32 h-32 bg-indigo-500/10 blur-3xl opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>

        <div class="relative z-10">
          <div class="flex items-center gap-3 mb-8 text-indigo-400">
            <div class="p-2.5 rounded-xl bg-zinc-800 border border-zinc-700 group-hover:bg-indigo-500/10 group-hover:border-indigo-500/20 transition-all duration-500">
              <Icon name={group.icon} class="w-6 h-6" />
            </div>
            <h3 class="text-lg font-bold text-zinc-100 group-hover:text-white transition-colors">{group.title}</h3>
          </div>
          
          <ul class="space-y-4">
            {group.skills.map((skill) => (
              <li class="flex items-center gap-3 text-sm text-zinc-400 group-hover:text-zinc-300 transition-colors">
                <span class="w-1.5 h-1.5 rounded-full bg-zinc-700 group-hover:bg-indigo-500 transition-all duration-500 shadow-[0_0_8px_rgba(99,102,241,0)] group-hover:shadow-[0_0_8px_rgba(99,102,241,0.5)]"></span>
                {skill}
              </li>
            ))}
          </ul>
        </div>

        <div class="absolute bottom-0 left-0 w-full h-0.5 bg-gradient-to-r from-transparent via-indigo-500/20 to-transparent scale-x-0 group-hover:scale-x-100 transition-transform duration-700"></div>
      </div>
    ))}
  </div>
</section>
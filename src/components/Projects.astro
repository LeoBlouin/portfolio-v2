---
import { getCollection } from 'astro:content';
import { Icon } from 'astro-icon/components';

const projects = await getCollection('projects');
const sortedProjects = projects.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<section id="projects" class="section-container relative">
  <div class="flex flex-col gap-4 mb-12">
    <h2 class="text-3xl md:text-4xl font-bold">Projets sélectionnés</h2>
    <p class="text-zinc-400 max-w-xl">
      Une sélection d'applications fullstack et d'outils open-source mettant l'accent sur la performance et l'expérience utilisateur.
    </p>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    {sortedProjects.map((project) => (
      <article class="group relative p-8 rounded-3xl border border-zinc-800 bg-zinc-900/20 hover:bg-zinc-900/40 hover:border-indigo-500/50 transition-all duration-500">

        <div class="flex justify-between items-start mb-6">
          <div class="p-3 rounded-2xl bg-zinc-800 group-hover:bg-indigo-500/10 group-hover:text-indigo-400 transition-colors">
            <Icon name={project.data.icon || 'lucide:code'} class="w-6 h-6" />
          </div>
          <div class="flex gap-3">
            {project.data.github && (
              <a href={project.data.github} target="_blank" class="text-zinc-500 hover:text-white transition-colors" aria-label="GitHub">
                <Icon name="lucide:github" class="w-5 h-5" />
              </a>
            )}
            {project.data.link && (
              <a href={project.data.link} target="_blank" class="text-zinc-500 hover:text-white transition-colors" aria-label="Lien externe">
                <Icon name="lucide:external-link" class="w-5 h-5" />
              </a>
            )}
          </div>
        </div>

        <h3 class="text-xl font-bold text-white mb-3 group-hover:text-indigo-400 transition-colors">
          {project.data.title}
        </h3>
        
        <p class="text-zinc-400 text-sm leading-relaxed mb-8">
          {project.data.description}
        </p>

        <div class="flex flex-wrap gap-2 mt-auto">
          {project.data.stack.map((tech: string) => (
            <span class="px-2.5 py-1 text-[10px] font-mono font-medium bg-zinc-800/50 text-zinc-400 rounded-md border border-zinc-700 group-hover:border-zinc-600 transition-colors">
              {tech}
            </span>
          ))}
        </div>

        <div class="absolute -bottom-px left-1/2 -translate-x-1/2 w-1/2 h-px bg-linear-to-r from-transparent via-indigo-500 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
      </article>
    ))}
  </div>
</section>
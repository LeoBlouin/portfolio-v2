---
import { getCollection } from 'astro:content';
import { Icon } from 'astro-icon/components';

const projects = await getCollection('projects');
const sortedProjects = projects.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<section id="projects" class="section-container relative">
	<div class="flex flex-col gap-4 mb-12">
		<h2 class="text-3xl md:text-4xl font-bold">Projets sélectionnés</h2>
		<p class="text-zinc-400 max-w-xl">
			Une sélection d'applications fullstack et d'outils open-source mettant l'accent sur la
			performance et l'expérience utilisateur.
		</p>
	</div>

	<div class="grid grid-cols-1 md:grid-cols-2 gap-6">
		{
			sortedProjects.map(project => (
				<article class="relative bg-zinc-950 rounded-xl border border-zinc-800 overflow-hidden shadow-2xl transition-all duration-300 hover:border-brand-primary/50">
					<div class="flex items-center justify-between px-4 py-2 bg-zinc-900/50 border-b border-zinc-800">
						<div class="flex gap-1.5">
							<div class="size-2.5 rounded-full bg-red-500/80 transition-colors"></div>
							<div class="size-2.5 rounded-full bg-amber-500/80 transition-colors"></div>
							<div class="size-2.5 rounded-full bg-emerald-500/80 transition-colors"></div>
						</div>
						<span class="text-[10px] font-mono text-zinc-500 uppercase tracking-widest">{project.data.title.replace(/\s+/g, '')}_project.ts</span>
					</div>

					<div class="p-6">
						<div class="flex justify-between items-start mb-4">
							<h3 class="text-lg font-mono font-bold text-indigo-400">
								<span class="text-zinc-600">const</span> {project.data.title.replace(/\s+/g, '')}
							</h3>
							<div class="flex gap-3">
								{project.data.github && (
									<a href={project.data.github} class="text-zinc-500 hover:text-white transition-colors"><Icon name="lucide:github" class="size-5" /></a>
								)}
								{project.data.link && (
									<a href={project.data.link} class="text-zinc-500 hover:text-white transition-colors"><Icon name="lucide:external-link" class="size-5" /></a>
								)}
							</div>
						</div>

						<div class="font-mono text-sm mb-6">
							<p class="text-zinc-500 italic">/**</p>
							<p class="text-zinc-400 px-4 leading-relaxed border-l border-zinc-800 ml-1 text-justify">
								{project.data.description}
							</p>
							<p class="text-zinc-500 italic px-1"> */</p>
						</div>

						<div class="flex flex-wrap gap-x-3 gap-y-2 font-mono text-[11px]">
							<span class="text-indigo-500">stack:</span>
							<span class="text-zinc-600">[</span>
							{project.data.stack.map((tech: string, index: number) => (
								<span class="text-amber-200/80">
									'{tech}'{index < project.data.stack.length - 1 ? ',' : ''}
								</span>
							))}
							<span class="text-zinc-600">]</span>
						</div>
					</div>

					<div class="absolute inset-0 pointer-events-none opacity-0 group-hover:opacity-[0.03] bg-[linear-gradient(rgba(18,16,16,0)_50%,rgba(0,0,0,0.25)_50%),linear-gradient(90deg,rgba(255,0,0,0.06),rgba(0,255,0,0.02),rgba(0,0,255,0.06))] bg-size-[100%_2px,3px_100%]"></div>
				</article>
			))
		}
	</div>
</section>

---
import { Icon } from 'astro-icon/components';

interface Props {
	isFreelance?: boolean;
}

const { isFreelance = false } = Astro.props;

const currentYear = new Date().getFullYear();

const socialLinks = [
  { name: 'GitHub', href: 'https://github.com/LeoBlouin', icon: 'lucide:github' },
  { name: 'LinkedIn', href: 'https://www.linkedin.com/in/leoblouin/', icon: 'lucide:linkedin' },
];
---

<footer class={`pt-20 border-t border-zinc-900 ${isFreelance ? 'bg-linear-to-br from-indigo-950 to-zinc-950' : 'bg-zinc-950-50'}`}>
  <div class="section-container py-12">
    <div class="flex flex-col md:flex-row justify-between items-center gap-8">
      
      <div class="flex flex-col items-center md:items-start gap-2">
        <a href="/" class="text-xl font-bold text-white tracking-tighter">
          Léo Blouin<span class="text-indigo-500">.</span>
        </a>
        <p class="text-zinc-500 text-sm font-mono">
          Développeur Fullstack • {currentYear}
        </p>
      </div>

      <div class="flex items-center gap-6">
        {socialLinks.map((link) => (
          <a 
            href={link.href} 
            target="_blank" 
            rel="noopener noreferrer"
            class="group flex items-center gap-2 text-zinc-500 hover:text-white transition-colors text-sm font-medium"
          >
            <Icon name={link.icon} class="w-5 h-5 group-hover:text-indigo-400 transition-colors" />
            <span class="hidden sm:inline">{link.name}</span>
          </a>
        ))}
      </div>

      <div class="flex items-center gap-3 px-4 py-2 rounded-2xl bg-zinc-900/50 border border-zinc-800">
        <span class="text-[10px] font-mono uppercase tracking-widest text-zinc-500">Built with</span>
        <div class="flex gap-2">
          <Icon name="lucide:rocket" class="w-4 h-4 text-orange-500" title="Astro" />
          <Icon name="lucide:wind" class="w-4 h-4 text-cyan-400" title="Tailwind 4" />
          <Icon name="lucide:code-2" class="w-4 h-4 text-blue-500" title="TypeScript" />
        </div>
      </div>

    </div>

    <div class="mt-12 pt-8 border-t border-zinc-900/50 text-center">
      <p class="text-zinc-600 text-[11px] font-mono uppercase tracking-[0.2em]">
        &copy; {currentYear} • Tous droits réservés • Rennes, France
      </p>
    </div>
  </div>
</footer>
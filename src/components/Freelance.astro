---
import { Icon } from 'astro-icon/components';
---

<section class="section-container">
  <div class="p-8 md:p-12 rounded-3xl bg-linear-to-br from-zinc-900 to-zinc-950 border border-zinc-800 relative overflow-hidden hover:bg-zinc-900/40 hover:border-indigo-500/50 transition-all duration-500">
    <div class="absolute top-0 right-0 -translate-y-1/2 translate-x-1/2 w-64 h-64 bg-indigo-500/10 blur-3xl rounded-full"></div>

    <div class="relative z-10 max-w-2xl">
      <span class="text-indigo-400 font-mono text-xs uppercase tracking-[0.2em] font-bold">
        Votre activité mérite une vitrine à sa hauteur
      </span>

      <h2 class="text-2xl md:text-4xl font-bold text-white mt-4 mb-6 leading-tight">
        Besoin d'un site internet <br class="hidden md:block"/> qui vous apporte des clients ?
      </h2>
      
      <p class="text-zinc-400 mb-10 text-lg leading-relaxed">
        Vous êtes <strong>artisan ou indépendant</strong> ? Je crée votre site internet clé en main : moderne, rapide et surtout <strong>facile à trouver sur Google</strong> pour booster votre visibilité locale.
      </p>

      <a 
        href="/freelance" 
        class="group inline-flex items-center gap-3 px-8 py-4 rounded-2xl bg-white text-zinc-950 font-bold text-sm hover:bg-indigo-50 hover:scale-[1.02] active:scale-95 transition-all duration-300 shadow-lg hover:shadow-indigo-500/10"
      >
        Découvrir mon offre pour les pros
        <Icon 
          name="lucide:arrow-right" 
          class="w-5 h-5 transition-transform duration-300 group-hover:translate-x-1.5 text-indigo-600" 
        />
      </a>
    </div>
  </div>
</section>
---
import { Icon } from 'astro-icon/components';

const { isFreelance = false } = Astro.props;

const navLinksPortfolio = [
  { name: 'À propos', href: '#about' },
  { name: 'Projets', href: '#projects' },
  { name: 'Expériences', href: '#experience' },
  { name: 'Contact', href: '#contact' },
];

const navLinksFreelance = [
  { name: 'L’Offre', href: '#offre' },
  { name: 'Ma Méthode', href: '#methode' },
  { name: 'Contact', href: '#contact' },
];
---

<header class="fixed top-0 left-0 right-0 z-50 flex justify-center p-4 sm:p-6">
  <nav id="main-nav" class={`flex items-center justify-between w-full max-w-5xl gap-2 p-1.5 px-4 backdrop-blur-md border rounded-full shadow-lg transition-all duration-300 shadow-indigo-600/15 ${isFreelance ? 'bg-white/80 border-zinc-700/10' : 'bg-zinc-900/80 border-zinc-700/50'}`}>
    
    <a href="/" class="flex items-center gap-2 px-3 py-1 group shrink-0">
      <div class="w-8 h-8 bg-indigo-600 rounded-lg flex items-center justify-center group-hover:bg-indigo-500 transition-colors shadow-lg shadow-indigo-500/20">
        <Icon name="lucide:terminal" class="w-5 h-5 text-white" />
      </div>
      <span class={`font-bold tracking-tight ${isFreelance ? 'text-zinc-950' : 'text-zinc-100'}`}>Léo Blouin<span class="text-indigo-500">.</span></span>
    </a>

    <ul class="hidden md:flex items-center gap-1">
      {(isFreelance ? navLinksFreelance : navLinksPortfolio).map((item) => (
        <li>
          <a href={item.href} class={`text-sm font-medium px-4 py-2 rounded-full transition-all ${isFreelance ? 'text-zinc-800 hover:text-white hover:bg-linear-to-tl from-indigo-900 to-indigo-600' : 'text-zinc-400 hover:text-white hover:bg-zinc-800'}`}>
            {item.name}
          </a>
        </li>
      ))}
    </ul>

    <div class="flex items-center gap-1">
      <div class={isFreelance ? 'hidden' : 'hidden sm:flex items-center mr-2'}>
        <a href="https://github.com/LeoBlouin" target="_blank" class="p-2 text-zinc-400 hover:text-indigo-400 transition-colors" aria-label="GitHub">
          <Icon name="lucide:github" class="w-5 h-5" />
        </a>
      </div>

      <a href={isFreelance ? '/' : '/freelance'} class="hidden lg:block px-5 py-2 rounded-full border border-indigo-500/30 text-indigo-400 text-sm font-mono hover:bg-indigo-500/10 transition-all font-bold">
        {isFreelance ? 'Portfolio': 'Création Site Web'}
      </a>

      <button id="menu-toggle" class="lg:hidden p-2 text-zinc-300 hover:bg-zinc-800 rounded-xl transition-colors z-1001 cursor-pointer" aria-label="Menu">
        <Icon name="lucide:menu" class="w-6 h-6 block" id="menu-icon" />
        <Icon name="lucide:x" class="w-6 h-6 hidden" id="close-icon" />
      </button>
    </div>
  </nav>
</header>

<div 
  id="mobile-menu" 
  data-open="false"
  class="fixed inset-0 bg-zinc-950 z-1000 hidden flex-col p-8 pt-20 transition-transform duration-500 ease-[cubic-bezier(0.16,1,0.3,1)] translate-y-full data-[open=true]:translate-y-0"
>
  <div class="absolute inset-0 bg-zinc-950 -z-20"></div>
  <div class="absolute inset-0 overflow-hidden -z-10">
      <div class="absolute top-[-10%] right-[-10%] w-96 h-96 bg-indigo-600/20 blur-[120px] rounded-full"></div>
      <div class="absolute bottom-[-10%] left-[-10%] w-96 h-96 bg-cyan-600/10 blur-[120px] rounded-full"></div>
  </div>

  <nav class="w-full max-w-lg mx-auto flex flex-col gap-10">
    <ul class="flex flex-col gap-6">
      {(isFreelance ? navLinksFreelance : navLinksPortfolio).map((item, index) => (
        <li 
          class="mobile-nav-item opacity-0 translate-y-8 transition-all duration-700 ease-[cubic-bezier(0.16,1,0.3,1)]" 
          style={`transition-delay: ${index * 50}ms`}
        >
          <a href={item.href} class="mobile-nav-link group flex items-center gap-4 text-5xl font-bold text-white hover:text-indigo-400 transition-all duration-300">
            <span class="text-indigo-500 text-2xl opacity-0 -translate-x-4 group-hover:opacity-100 group-hover:translate-x-0 transition-all">-</span>
            {item.name}
          </a>
        </li>
      ))}
    </ul>
    
    <div class="h-px w-full bg-zinc-800/50 mobile-nav-item opacity-0 translate-y-8" style="transition-delay: 250ms"></div>

    <div class="mobile-nav-item opacity-0 translate-y-8 transition-all duration-700" style="transition-delay: 300ms">
      <a href={isFreelance ? '/' : '/freelance'} class="group flex items-center justify-between p-6 rounded-3xl bg-white text-zinc-950 shadow-2xl hover:bg-zinc-100 transition-colors">
        <div class="flex flex-col text-left">
          <span class="text-[10px] font-mono uppercase tracking-[0.2em] text-zinc-500 mb-1">{isFreelance ? 'Ma vitrine' : 'Service Pro'}</span>
          <span class="text-xl font-bold">{isFreelance ? 'Portfolio': 'Création Site Web'}</span>
        </div>
        <div class="w-12 h-12 bg-indigo-600 rounded-2xl flex items-center justify-center text-white transition-transform group-active:scale-90">
          <Icon name="lucide:arrow-right" class="w-6 h-6" />
        </div>
      </a>
    </div>

    <div class="flex items-center justify-between mobile-nav-item opacity-0 translate-y-8 transition-all duration-700" style="transition-delay: 350ms">
       <div class="flex gap-4">
         <a href="https://github.com/LeoBlouin/" class="p-4 bg-zinc-900 border border-zinc-800 rounded-2xl text-zinc-400 hover:text-white transition-colors duration-300"><Icon name="lucide:github" class="w-6 h-6" /></a>
         <a href="https://www.linkedin.com/in/leoblouin/" class="p-4 bg-zinc-900 border border-zinc-800 rounded-2xl text-zinc-400 hover:text-white transition-colors duration-300"><Icon name="lucide:linkedin" class="w-6 h-6" /></a>
       </div>
       <button id="mobile-close-btn" class="text-xs font-mono uppercase tracking-widest text-zinc-500 hover:text-white border border-zinc-800 rounded-full py-2 px-4 cursor-pointer transition-colors">Fermer</button>
    </div>
  </nav>
</div>

<script>
  // On utilise 'astro:page-load' pour que le script se relance à chaque changement de page
  document.addEventListener('astro:page-load', () => {
    const toggleBtn = document.getElementById('menu-toggle');
    const mobileMenu = document.getElementById('mobile-menu');
    const menuIcon = document.getElementById('menu-icon');
    const closeIcon = document.getElementById('close-icon');
    const menuItems = document.querySelectorAll('.mobile-nav-item');
    const closeBtnBottom = document.getElementById('mobile-close-btn');

    // Sécurité : on vérifie que les éléments existent sur la page actuelle
    if (!toggleBtn || !mobileMenu) return;

    const openMenu = () => {
      mobileMenu.classList.remove('hidden');
      mobileMenu.classList.add('flex');
      
      requestAnimationFrame(() => {
        mobileMenu.setAttribute('data-open', 'true');
        menuItems.forEach(item => {
          item.classList.remove('opacity-0', 'translate-y-8');
          item.classList.add('opacity-100', 'translate-y-0');
        });
      });

      document.body.style.overflow = 'hidden';
      menuIcon?.classList.add('hidden');
      closeIcon?.classList.remove('hidden');
    };

    const closeMenu = () => {
      mobileMenu.setAttribute('data-open', 'false');
      menuItems.forEach(item => {
        item.classList.add('opacity-0', 'translate-y-8');
        item.classList.remove('opacity-100', 'translate-y-0');
      });

      setTimeout(() => {
        mobileMenu.classList.add('hidden');
        mobileMenu.classList.remove('flex');
        document.body.style.overflow = '';
      }, 500);

      menuIcon?.classList.remove('hidden');
      closeIcon?.classList.add('hidden');
    };

    // Nettoyage des événements précédents (optionnel mais propre)
    toggleBtn.removeEventListener('click', openMenu);
    
    toggleBtn.addEventListener('click', () => {
      const isOpened = mobileMenu.getAttribute('data-open') === 'true';
      isOpened ? closeMenu() : openMenu();
    });

    closeBtnBottom?.addEventListener('click', closeMenu);
    
    document.querySelectorAll('.mobile-nav-link').forEach(link => {
      link.addEventListener('click', closeMenu);
    });
  });
</script>

<style>
  /* Gestion du Stagger à la fermeture : on réduit les délais pour que ça soit plus nerveux */
  #mobile-menu[data-open="false"] .mobile-nav-item {
    transition-delay: 0s !important;
    transition-duration: 300ms;
  }
  
  /* Ton animation de scroll header reste identique */
  header {
    animation: nav-reveal linear both;
    animation-timeline: scroll();
    animation-range: 0 100px;
  }
  @keyframes nav-reveal { to { transform: translateY(-4px) scale(0.98); } }
</style>
---
import { Icon } from 'astro-icon/components';

const stack = [
	{ name: 'TypeScript', icon: 'lucide:code-2', color: 'group-hover:text-blue-500' },
	{ name: 'React', icon: 'lucide:atom', color: 'group-hover:text-cyan-400' },
	{ name: 'Next.js', icon: 'lucide:zap', color: 'group-hover:text-white' },
	{ name: 'Tailwind CSS 4', icon: 'lucide:wind', color: 'group-hover:text-cyan-400' },
	{ name: 'Astro', icon: 'lucide:rocket', color: 'group-hover:text-orange-500' },
	{ name: 'NestJS', icon: 'lucide:server', color: 'group-hover:text-red-500' },
	{ name: 'PostgreSQL', icon: 'lucide:database', color: 'group-hover:text-indigo-400' },
];
---

<section class="relative pt-16 pb-20 md:pt-36 md:pb-32 overflow-hidden">
	<div
		class="absolute top-0 left-1/2 -translate-x-1/2 w-full max-w-4xl h-96 bg-indigo-500/10 blur-[120px] -z-10 rounded-full">
	</div>

	<div class="section-container">
		<div class="flex flex-col items-center text-center">
			<div
				class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-indigo-500/10 border border-indigo-500/20 text-indigo-400 text-xs font-medium mb-6 animate-fade-in">
				<span class="relative flex h-2 w-2">
					<span
						class="animate-ping absolute inline-flex h-full w-full rounded-full bg-indigo-400 opacity-75"
					></span>
					<span class="relative inline-flex rounded-full h-2 w-2 bg-indigo-500"></span>
				</span>
				Développeur Fullstack depuis 2021
			</div>

			<div class="flex flex-col gap-4">
				<span class="text-indigo-400 font-mono text-sm tracking-[0.3em] uppercase">
					Léo Blouin — Développeur Fullstack
				</span>

				<h1 class="text-4xl md:text-6xl lg:text-7xl font-bold tracking-tight text-white mb-6">
					Construire des solutions <br />
					<span class="bg-clip-text text-transparent bg-linear-to-r from-indigo-400 to-cyan-400">
						robustes et performantes.
					</span>
				</h1>
			</div>

			<p class="max-w-2xl text-lg text-zinc-400 leading-relaxed mb-10">
				Expert en écosystème <span class="text-zinc-100">TypeScript</span>. Je conçois des
				architectures backend scalables avec <span class="text-zinc-100">NestJS</span>
				et des interfaces frontend ultra-rapides grâce à <span class="text-zinc-100">React</span> ou <span
					class="text-zinc-100">Astro</span
				>.
			</p>

			<div class="flex flex-wrap justify-center gap-4 mb-16">
				<a
					href="#projects"
					class="px-8 py-3 bg-white text-black font-semibold rounded-xl hover:bg-zinc-200 transition-colors flex items-center gap-2">
					<Icon name="lucide:layers" class="w-5 h-5" />
					Voir mes projets
				</a>
				<a
					href="#contact"
					class="px-8 py-3 bg-zinc-900 text-white font-semibold rounded-xl border border-zinc-800 hover:border-zinc-700 transition-colors flex items-center gap-2">
					Me contacter
				</a>
			</div>

			<div class="w-full max-w-3xl pt-10 border-t border-zinc-900">
				<p class="text-xs uppercase tracking-[0.2em] text-zinc-500 mb-8 font-semibold">
					Ma stack de prédilection
				</p>
				<div
					class="flex flex-wrap justify-center items-center gap-8 md:gap-12 opacity-50 grayscale hover:grayscale-0 transition-all duration-500">
					{
						stack.map(tech => (
							<div class="flex flex-col items-center gap-2 group cursor-default">
								<Icon
									name={tech.icon}
									class={`size-8 transition-colors duration-300 ${tech.color}`}
								/>
								<span class="text-[10px] font-mono font-medium uppercase tracking-tighter">
									{tech.name}
								</span>
							</div>
						))
					}
				</div>
			</div>
		</div>
	</div>
</section>

<style>
	.animate-fade-in {
		animation: fadeIn 0.8s ease-out forwards;
	}

	@keyframes fadeIn {
		from {
			opacity: 0;
			transform: translateY(10px);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}
</style>

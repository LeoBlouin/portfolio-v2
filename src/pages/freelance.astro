---
import Layout from '../layouts/Layout.astro';
import { Icon } from 'astro-icon/components';

const performanceItems = [
	{ label: 'Visibilité Google', val: '100%' },
	{ label: 'Vitesse de chargement', val: '100%' },
	{ label: 'Expérience Mobile', val: '100%' },
	{ label: 'Sécurité SSL', val: '100%' },
];

const argumentsVente = [
	{
		title: 'Design Sur-Mesure',
		desc: 'Pas de template déjà vu. Votre site reflète l’identité et la qualité de votre travail d’artisan.',
		icon: 'lucide:palette',
	},
	{
		title: 'Ultra-Mobile',
		desc: '61% de vos clients utilisent leur téléphone. Votre site sera fluide et rapide sur tous les écrans.',
		icon: 'lucide:smartphone',
	},
	{
		title: 'Optimisé Google',
		desc: 'Je travaille votre référencement local pour que les clients de votre région vous trouvent en premier.',
		icon: 'lucide:search',
	},
];

const methodeItems = [
	{
		t: 'Livraison Express en 7 jours',
		d: 'Pas de projets qui traînent. En une semaine, vous êtes visible partout.',
		icon: 'lucide:zap',
	},
	{
		t: 'Maintenance & Sérénité',
		d: 'Hébergement pro et mises à jour inclus. Je reste votre interlocuteur technique.',
		icon: 'lucide:wrench',
	},
	{
		t: 'Accompagnement humain',
		d: 'Je suis votre unique interlocuteur. Pas de plateforme de support anonyme.',
		icon: 'lucide:heart-handshake',
	},
];

const processusSteps = [
	{
		step: '1',
		title: 'On définit vos besoins',
		desc: 'Un court échange pour comprendre votre activité et vos concurrents.',
	},
	{
		step: '2',
		title: 'Conception & SEO',
		desc: 'Je développe votre site sur-mesure pensé pour Google et la conversion.',
	},
	{
		step: '3',
		title: 'Lancement & Succès',
		desc: 'Votre site est en ligne. Vous n’avez plus qu’à répondre aux devis.',
	},
];
---

<Layout title="Léo Blouin | Sites internet pour Artisans & Indépendants" isFreelance>
	<div
		class="min-h-screen bg-[#fcfcfd] text-indigo-950 selection:bg-indigo-100 relative overflow-x-hidden pt-20">
		<section id="offre" class="max-w-7xl mx-auto px-6 pt-12 pb-16 md:pt-24 md:pb-32">
			<div
				class="inline-flex items-center mb-6 px-4 py-1 rounded-full bg-white text-indigo-600 text-xs md:text-sm font-bold uppercase border border-indigo-100 shadow-sm">
				🚀 Disponible pour booster votre activité
			</div>
			<div class="grid lg:grid-cols-2 gap-12 items-center text-left">
				<div>
					<h1
						class="text-5xl md:text-7xl font-extrabold tracking-tight mb-8 leading-[1.1] text-indigo-950">
						Un site qui ramène <br class="hidden md:block" />
						<span class="text-indigo-600 font-black">vraiment des clients.</span>
					</h1>
					<p class="text-xl md:text-2xl text-zinc-600 mb-10 leading-relaxed max-w-2xl">
						Vous êtes expert dans votre métier, je le suis dans le mien. Je crée votre vitrine pro <strong
							class="font-bold">en 7 jours</strong
						>, optimisée pour Google.
					</p>
					<div class="flex flex-col sm:flex-row gap-5">
						<a
							href="#contact"
							class="bg-indigo-600 text-white px-10 py-5 rounded-2xl font-bold text-xl shadow-lg hover:bg-zinc-900 hover:-translate-y-1 transition-all duration-300 text-center">
							Lancer mon projet
						</a>
						<a
							href="#methode"
							class="bg-white text-zinc-700 px-10 py-5 rounded-2xl font-bold text-xl border border-zinc-200 hover:border-indigo-600 hover:text-indigo-600 transition-all duration-300 text-center">
							Ma méthode
						</a>
					</div>
				</div>

				<div class="relative group">
					<div
						class="absolute -inset-1 bg-linear-to-r from-indigo-600 to-blue-500 rounded-3xl blur opacity-20 group-hover:opacity-40 transition duration-1000">
					</div>
					<div
						class="relative bg-white border border-zinc-100 rounded-3xl shadow-2xl p-8 md:p-12 transform hover:scale-[1.01] transition-all">
						<p class="text-sm font-black text-zinc-400 uppercase tracking-[0.2em] mb-8 text-center">
							Analyses & Performance Réelle
						</p>
						<div class="space-y-7">
							{
								performanceItems.map(item => (
									<div class="space-y-2">
										<div class="flex justify-between text-sm md:text-base font-bold">
											<span class="text-zinc-800">{item.label}</span>
											<span class="text-indigo-600 font-black">{item.val}</span>
										</div>
										<div class="h-3 w-full bg-zinc-100 rounded-full overflow-hidden">
											<div class="h-full bg-indigo-600 rounded-full shadow-[0_0_15px_rgba(79,70,229,0.4)] w-full transition-all duration-1000" />
										</div>
									</div>
								))
							}
						</div>
					</div>
				</div>
			</div>
		</section>

		<section class="max-w-7xl mx-auto px-6 py-12">
			<div class="grid md:grid-cols-3 gap-8 text-left">
				{
					argumentsVente.map(card => (
						<div class="bg-white p-8 rounded-3xl border border-zinc-100 shadow-sm hover:shadow-xl hover:border-indigo-100 transition-all duration-300 group text-left">
							<div class="w-14 h-14 rounded-2xl bg-indigo-50 flex items-center justify-center mb-6 group-hover:bg-indigo-600 group-hover:text-white transition-colors">
								<Icon name={card.icon} class="w-7 h-7" />
							</div>
							<h3 class="text-2xl font-bold mb-4 text-indigo-950">{card.title}</h3>
							<p class="text-zinc-500 text-lg leading-relaxed">{card.desc}</p>
						</div>
					))
				}
			</div>
		</section>

		<section id="methode" class="max-w-7xl mx-auto px-6 py-16">
			<div
				class="bg-linear-to-br from-indigo-950 to-zinc-950 rounded-3xl p-8 md:p-20 text-white shadow-2xl relative overflow-hidden">
				<div class="relative z-10 grid lg:grid-cols-2 gap-16 items-center text-left">
					<div>
						<h2 class="text-4xl md:text-6xl font-bold mb-8 leading-tight">
							Arrêtez de perdre des clients à cause d'un site lent.
						</h2>
						<p class="text-zinc-400 text-xl mb-10 leading-relaxed">
							Aujourd'hui, 80% de vos clients vous cherchent sur Google. Si votre site n'est pas
							rapide ou mal référencé, vous donnez du travail à vos concurrents. Je m'occupe de tout
							le côté technique.
						</p>
						<div class="grid grid-cols-1 sm:grid-cols-2 gap-6 font-bold text-indigo-300 text-lg">
							<div class="flex items-center gap-3">
								<Icon name="lucide:shield-check" class="w-6 h-6" /> Zéro maintenance
							</div>
							<div class="flex items-center gap-3">
								<Icon name="lucide:trending-up" class="w-6 h-6" /> SEO local optimisé
							</div>
						</div>
					</div>
					<div class="space-y-5">
						{
							methodeItems.map(item => (
								<div class="p-8 bg-zinc-800/50 backdrop-blur-sm rounded-2xl border border-zinc-700 hover:border-indigo-500 transition-all group">
									<div class="flex items-start gap-4">
										<div class="shrink-0 mt-1 text-indigo-400 group-hover:text-indigo-300 transition-colors">
											<Icon name={item.icon} class="w-6 h-6" />
										</div>
										<div>
											<h3 class="text-xl font-bold text-white mb-2 group-hover:text-indigo-300 transition-colors">
												{item.t}
											</h3>
											<p class="text-zinc-400 leading-relaxed">{item.d}</p>
										</div>
									</div>
								</div>
							))
						}
					</div>
				</div>
			</div>
		</section>

		<section class="max-w-7xl mx-auto px-6 py-28 text-center">
			<h2 class="text-4xl md:text-6xl font-bold mb-28 text-indigo-950">
				Une mise en ligne sans stress
			</h2>
			<div class="grid md:grid-cols-3 gap-12">
				{
					processusSteps.map(item => (
						<div class="bg-white p-10 rounded-3xl border border-zinc-100 shadow-sm relative group hover:shadow-xl transition-all text-left">
							<div class="absolute -top-7 left-10 bg-indigo-600 text-white w-14 h-14 rounded-2xl flex items-center justify-center font-black text-xl shadow-lg transform group-hover:rotate-6 transition-transform">
								{item.step}
							</div>
							<h3 class="text-2xl font-bold mt-6 mb-4 text-indigo-950">{item.title}</h3>
							<p class="text-zinc-600 text-lg leading-relaxed">{item.desc}</p>
						</div>
					))
				}
			</div>
		</section>

		<section id="contact" class="max-w-7xl mx-auto px-6 py-20">
			<div
				class="bg-white rounded-3xl overflow-hidden shadow-2xl border border-indigo-100 grid lg:grid-cols-2">
				<div class="p-8 md:p-20 bg-indigo-600 text-white flex flex-col justify-center text-left">
					<h2 class="text-4xl md:text-6xl font-bold mb-8 leading-tight">On commence quand ?</h2>
					<p class="text-indigo-100 text-xl mb-12">
						Expliquez-moi votre projet en quelques mots. Je vous recontacte sous 24h.
					</p>
					<div class="space-y-8">
						<a href="tel:+33760960480" class="flex items-center gap-6 group">
							<div
								class="w-12 h-12 rounded-xl bg-white/20 flex items-center justify-center text-xl shadow-inner group-hover:bg-white/30 transition-all">
								<Icon name="lucide:phone" />
							</div>
							<div>
								<p class="text-[10px] font-black text-indigo-200 uppercase tracking-widest">
									Appel direct
								</p>
								<p
									class="text-xl md:text-2xl font-bold group-hover:text-indigo-200 transition-colors">
									07 60 96 04 80
								</p>
							</div>
						</a>
						<a
							href="mailto:leoblouinpro@gmail.com"
							class="flex items-center gap-6 group overflow-hidden">
							<div
								class="w-12 h-12 rounded-xl bg-white/20 flex items-center justify-center text-xl shadow-inner group-hover:bg-white/30 transition-all shrink-0">
								<Icon name="lucide:mail" />
							</div>
							<div class="overflow-hidden text-left">
								<p class="text-[10px] font-black text-indigo-200 uppercase tracking-widest">
									Email pro
								</p>
								<p
									class="text-lg md:text-2xl font-bold group-hover:text-indigo-200 transition-colors break-all">
									leoblouinpro@gmail.com
								</p>
							</div>
						</a>
					</div>
				</div>

				<div class="p-8 md:p-20">
					<form id="contact-form" class="space-y-6">
						<div class="grid md:grid-cols-2 gap-6">
							<div class="space-y-2 text-left">
								<label class="text-[10px] font-black text-zinc-500 uppercase tracking-widest"
									>Votre Nom</label
								>
								<input
									name="name"
									type="text"
									required
									placeholder="Jean Dupont"
									class="w-full p-4 bg-zinc-50 rounded-xl border border-zinc-200 focus:border-indigo-600 focus:ring-1 focus:ring-indigo-600 outline-none transition-all"
								/>
							</div>
							<div class="space-y-2 text-left">
								<label class="text-[10px] font-black text-zinc-500 uppercase tracking-widest"
									>Téléphone</label
								>
								<input
									name="phone"
									type="tel"
									required
									placeholder="06 00 00 00 00"
									class="w-full p-4 bg-zinc-50 rounded-xl border border-zinc-200 focus:border-indigo-600 focus:ring-1 focus:ring-indigo-600 outline-none transition-all"
								/>
							</div>
						</div>
						<div class="space-y-2 text-left">
							<label class="text-[10px] font-black text-zinc-500 uppercase tracking-widest"
								>Votre Email</label
							>
							<input
								name="email"
								type="email"
								required
								placeholder="jean.plomberie@gmail.com"
								class="w-full p-4 bg-zinc-50 rounded-xl border border-zinc-200 focus:border-indigo-600 focus:ring-1 focus:ring-indigo-600 outline-none transition-all"
							/>
						</div>
						<div class="space-y-2 text-left">
							<label class="text-[10px] font-black text-zinc-500 uppercase tracking-widest"
								>Votre projet</label
							>
							<textarea
								name="message"
								required
								rows="4"
								class="w-full p-4 bg-zinc-50 rounded-xl border border-zinc-200 focus:border-indigo-600 focus:ring-1 focus:ring-indigo-600 outline-none transition-all"
								placeholder="Parlez-moi de votre activité..."></textarea>
						</div>
						<button
							type="submit"
							id="submit-btn"
							class="w-full bg-indigo-600 text-white py-6 rounded-2xl font-bold text-xl hover:bg-zinc-900 transition-all shadow-xl active:scale-95 cursor-pointer"
							>Obtenir mon devis gratuit</button
						>
						<div id="status-msg" class="hidden text-center font-bold text-lg mt-6"></div>
					</form>
				</div>
			</div>
		</section>

		<a
			href="tel:+33760960480"
			class="md:hidden fixed bottom-8 right-8 w-16 h-16 bg-indigo-600 text-white rounded-2xl shadow-2xl flex items-center justify-center text-2xl z-50 border-2 border-white animate-bounce">
			<Icon name="lucide:phone" />
		</a>
	</div>
</Layout>

<script>
	document.addEventListener('astro:page-load', () => {
		const form = document.getElementById('contact-form') as HTMLFormElement;
		const btn = document.getElementById('submit-btn') as HTMLButtonElement;
		const msg = document.getElementById('status-msg');

		form?.addEventListener('submit', async e => {
			e.preventDefault();
			btn.disabled = true;
			btn.innerText = 'Envoi...';

			try {
				const response = await fetch('https://formspree.io/f/xjgezyba', {
					method: 'POST',
					body: new FormData(form),
					headers: { Accept: 'application/json' },
				});

				if (response.ok) {
					msg!.innerText = "✨ C'est envoyé ! Je vous rappelle vite.";
					msg!.className = 'text-center text-green-600 font-bold animate-bounce text-lg mt-6';
					form.reset();
				} else {
					throw new Error();
				}
			} catch {
				msg!.innerText = '❌ Erreur. Réessayez ou appelez-moi.';
				msg!.className = 'text-center text-red-500 font-bold text-lg mt-6';
			} finally {
				msg!.classList.remove('hidden');
				btn.disabled = false;
				btn.innerText = 'Obtenir mon devis gratuit';
			}
		});
	});
</script>
